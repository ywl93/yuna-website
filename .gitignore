# Dependencies (Netlify installs these during build)
node_modules/

# Local dev lockfiles / artifacts (Netlify runs its own install at build;
# `netlify dev` regenerates deno.lock each run)
package-lock.json
deno.lock

# Netlify local state
.netlify/

# Secrets / environment — NEVER commit Stripe keys
.env
.env.*
!.env.example

# Local-only Claude config
.claude/settings.local.json

# OS cruft
.DS_Store
Thumbs.db
